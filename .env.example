# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=

# Email / SMTP (Gmail example — use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Server
PORT=5000
NODE_ENV=production
FRONTEND_URL=http://localhost:3000
MAX_FILE_SIZE=5242880

# Frontend
REACT_APP_API_URL=http://localhost:5000
